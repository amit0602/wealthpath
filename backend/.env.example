# Database
DATABASE_URL="postgresql://wealthpath:wealthpath_dev@localhost:5432/wealthpath_db"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production
JWT_REFRESH_EXPIRES_IN=30d

# Encryption
ENCRYPTION_KEY=32_char_hex_key_change_in_production

# App
PORT=3000
NODE_ENV=development

# OTP (POC: logs OTP to console; production: replace with SMS provider)
OTP_TTL_SECONDS=300
