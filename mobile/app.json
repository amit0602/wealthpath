{
  "expo": {
    "name": "WealthPath",
    "slug": "wealthpath",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.wealthpath.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to securely access your financial data"
      }
    },
    "android": {
      "package": "com.wealthpath.app",
      "permissions": ["USE_FINGERPRINT", "USE_BIOMETRIC"]
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "apiBaseUrl": "http://localhost:3000/api/v1"
    }
  }
}
